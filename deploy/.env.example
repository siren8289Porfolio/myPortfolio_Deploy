# Runtime profile: local (H2/SQLite) | prod (PostgreSQL on AWS RDS)
SPRING_PROFILE=local
TZ=Asia/Seoul
NGINX_HTTP_PORT=80

# Production DB (EC2 — set when SPRING_PROFILE=prod)
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint:5432/portfolio
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# Briefly (non-Spring) production DB overrides
# DB_URL=jdbc:postgresql://your-rds-endpoint:5432/briefly
# DB_USERNAME=
# DB_PASSWORD=

# Mido — 자체 Postgres 컨테이너(mido-db) 사용. mido-app은 항상 prod 프로파일로 접속한다.
MIDO_SPRING_PROFILE=prod
MIDO_DB_NAME=mido
MIDO_DB_USER=postgres
MIDO_DB_PASSWORD=

# Golmok — 자체 Postgres 컨테이너(golmok-db) 사용. local(H2)로 두면 재시작마다
# 데이터가 초기화되고 Flyway 시드 데이터도 적용되지 않으므로 항상 prod로 접속한다.
GOLMOK_SPRING_PROFILE=prod
GOLMOK_DB_NAME=golmok
GOLMOK_DB_USER=postgres
GOLMOK_DB_PASSWORD=localdev

# GHCR (Phase 4+) — image registry for EC2 pull
GHCR_OWNER=siren8289
GHCR_IMAGE_TAG=latest

# AWS EC2 (Phase 2–3)
EC2_PUBLIC_IP=
EC2_USER=ubuntu
SSH_KEY_PATH=~/Downloads/portfolio-key.pem
REPO_URL=https://github.com/siren8289Porfolio/myPortfolio_Deploy.git
PROJECT_DIR=~/my-portfolio

# GitHub Actions Secrets (Phase 4) — Repository Settings → Secrets
# GHCR_USERNAME = GitHub username (e.g. siren8289) — EC2 pull 전용
# GHCR_TOKEN    = PAT with read:packages — EC2 pull 전용
# Actions push는 GITHUB_TOKEN 자동 사용 (packages: write 권한)
# EC2_HOST      = EC2_PUBLIC_IP
# EC2_USER      = ubuntu
# EC2_SSH_KEY   = PEM private key 전체 (portfolio-key.pem)
# EC2_PORT      = 22 (선택)

# AWS (Phase 5+)
# DOMAIN=
# AWS_REGION=ap-northeast-2
