# ===========================================
# 다시, 골목 — Production
# ===========================================
NODE_ENV=production
APP_VERSION=0.1.0

# Database (PostgreSQL / RDS)
DATABASE_URL="postgresql://app_user:CHANGE_ME@db-host:5432/dasi_golmok"
DB_HOST=db-host
DB_PORT=5432
DB_NAME=dasi_golmok
DB_USERNAME=app_user
DB_PASSWORD=CHANGE_ME

# Auth (maps to JWT_SECRET in Deployment Plan)
NEXTAUTH_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
NEXTAUTH_URL=https://your-domain.com

# Docker deploy
APP_PORT=3000
RUN_SEED=false

# Storage (future S3 migration)
# STORAGE_BUCKET=dasi-golmok-images
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# Map API (future)
# MAP_API_KEY=

# OAuth (optional)
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
