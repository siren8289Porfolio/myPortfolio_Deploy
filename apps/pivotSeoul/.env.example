# ── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=pivotseoul
POSTGRES_USER=pivotseoul
POSTGRES_PASSWORD=changeme_strong_password

# ── Spring Boot ─────────────────────────────────────
# CORS: 실제 서버 도메인/IP로 변경
PIVOT_CORS_ORIGINS=http://YOUR_SERVER_IP:3000

# ── Next.js (브라우저에서 직접 접근하는 API 주소) ────
# 서버 공인 IP 또는 도메인으로 변경
NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP:8080

# ── 프론트 노출 포트 (기본 3000) ─────────────────────
FRONT_PORT=3000
